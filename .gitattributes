# Auto detect text files and normalize to LF

* text=auto eol=lf

# Source code

*.java     text eol=lf
*.kt       text eol=lf
*.kts      text eol=lf

# Gradle

*.gradle   text eol=lf
*.properties text eol=lf

# XML / config

*.xml      text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf

# Shell scripts (important for CI)

*.sh       text eol=lf

# Windows scripts (keep CRLF)

*.bat      text eol=crlf
*.cmd      text eol=crlf

# Images & binaries (no conversion)

*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.keystore binary
*.jks      binary

# Gradle wrapper

gradlew    text eol=lf
gradlew.bat text eol=crlf
